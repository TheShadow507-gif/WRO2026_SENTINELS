#include <Servo.h>
#include <Arduino.h>

const int TRIG_DER = 2;
const int ECHO_DER = 4;

const int TRIG_IZQ = 12;
const int ECHO_IZQ = 13;

float der, izq;

const int ENA = 11;
const int IN3 = 10;
const int IN4 = 9;

const int SERVOPIN = 6;
Servo myServo;

int velRecta = 210;
int velCurva = 210;

int anguloRecto = 90;
int anguloIzq  = 50;
int anguloDer  = 130;

float UMBRAL_GIRO = 35;
float MARGEN_DIFERENCIA = 15;

// ---- Conteo de vueltas ----
const int GIROS_POR_VUELTA = 4;   // AJUSTA esto según las esquinas reales de tu pista
const int VUELTAS_OBJETIVO = 3;
const int GIROS_OBJETIVO = GIROS_POR_VUELTA * VUELTAS_OBJETIVO;

enum Estado { RECTO, IZQUIERDA, DERECHA };
Estado estadoActual = RECTO;
Estado estadoAnterior = RECTO;

int contadorGiros = 0;
bool detenido = false;

void setup() {
  Serial.begin(9600);

  pinMode(TRIG_DER, OUTPUT);
  pinMode(ECHO_DER, INPUT);

  pinMode(TRIG_IZQ, OUTPUT);
  pinMode(ECHO_IZQ, INPUT);

  pinMode(ENA, OUTPUT);
  pinMode(IN3, OUTPUT);
  pinMode(IN4, OUTPUT);

  myServo.attach(SERVOPIN);
  myServo.write(anguloRecto);

  digitalWrite(IN3, LOW);
  digitalWrite(IN4, HIGH);
  analogWrite(ENA, velRecta);
}

// Lee una sola vez el sensor
float leerDistancia(int trigPin, int echoPin) {
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);
  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);

  long duracion = pulseIn(echoPin, HIGH, 25000);
  if (duracion == 0) return 0;

  float distancia = duracion * 0.034 / 2;
  if (distancia < 3) return 0;  // descarta lecturas imposibles/ruido
  return distancia;
}

// Toma 3 lecturas y devuelve la mediana (mucho más estable que una sola lectura)
float leerDistanciaFiltrada(int trigPin, int echoPin) {
  float m1 = leerDistancia(trigPin, echoPin);
  delay(10);
  float m2 = leerDistancia(trigPin, echoPin);
  delay(10);
  float m3 = leerDistancia(trigPin, echoPin);

  if (m1 > m2) { float t = m1; m1 = m2; m2 = t; }
  if (m2 > m3) { float t = m2; m2 = m3; m3 = t; }
  if (m1 > m2) { float t = m1; m1 = m2; m2 = t; }
  return m2;
}

void irRecto() {
  myServo.write(anguloRecto);
  analogWrite(ENA, velRecta);
}

void girarIzquierda() {
  myServo.write(anguloIzq);
  analogWrite(ENA, velCurva);
}

void girarDerecha() {
  myServo.write(anguloDer);
  analogWrite(ENA, velCurva);
}

// Apaga TODO: motor y servo. El robot queda inmóvil de forma permanente.
void detenerTodo() {
  analogWrite(ENA, 0);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, LOW);
  myServo.write(anguloRecto);
  detenido = true;
  Serial.println("=== CIRCUITO COMPLETADO: ROBOT DETENIDO ===");
}

void loop() {
  if (detenido) return;   // ya terminó, no hace nada más

  der = leerDistanciaFiltrada(TRIG_DER, ECHO_DER);
  delay(30);
  izq = leerDistanciaFiltrada(TRIG_IZQ, ECHO_IZQ);
  delay(30);

  Serial.print("Der: "); Serial.print(der);
  Serial.print(" cm | Izq: "); Serial.print(izq);
  Serial.print(" cm | Giros: "); Serial.print(contadorGiros);
  Serial.print("/"); Serial.println(GIROS_OBJETIVO);

  float diferencia = izq - der;

  bool izqDisparaGiro = (izq > UMBRAL_GIRO) && (diferencia > MARGEN_DIFERENCIA);
  bool derDisparaGiro = (der > UMBRAL_GIRO) && (-diferencia > MARGEN_DIFERENCIA);

  if (izqDisparaGiro && !derDisparaGiro) {
    estadoActual = IZQUIERDA;
  }
  else if (derDisparaGiro && !izqDisparaGiro) {
    estadoActual = DERECHA;
  }
  else {
    estadoActual = RECTO;
  }

  // Cuenta un giro solo en el instante en que EMPIEZA (transición desde RECTO)
  if (estadoAnterior == RECTO && (estadoActual == IZQUIERDA || estadoActual == DERECHA)) {
    contadorGiros++;

    if (contadorGiros >= GIROS_OBJETIVO) {
      detenerTodo();
      return;
    }
  }
  estadoAnterior = estadoActual;

  if (estadoActual == IZQUIERDA) {
    girarIzquierda();
  } else if (estadoActual == DERECHA) {
    girarDerecha();
  } else {
    irRecto();
  }

  delay(100);
}

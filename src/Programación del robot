#include <Servo.h>
#include <Arduino.h>

const int TRIG_DER = 2;
const int ECHO_DER = 4;

const int TRIG_IZQ = 12;
const int ECHO_IZQ = 13;

long duracionDer, DuracionIzq;
float der, izq;

const int ENA = 11;
const int IN3 = 10;
const int IN4 = 9;

const int SERVOPIN = 6;
Servo myServo;

int velRecta = 210;
int velCurva = 210;

int anguloRecto = 90;
int anguloIzq  = 50;
int anguloDer  = 130;

float UMBRAL_GIRO = 35;
float MARGEN_DIFERENCIA = 15;

void setup() {
  Serial.begin(9600);

  pinMode(TRIG_DER, OUTPUT);
  pinMode(ECHO_DER, INPUT);

  pinMode(TRIG_IZQ, OUTPUT);
  pinMode(ECHO_IZQ, INPUT);

  pinMode(ENA, OUTPUT);
  pinMode(IN3, OUTPUT);
  pinMode(IN4, OUTPUT);

  myServo.attach(SERVOPIN);
  myServo.write(anguloRecto);

  digitalWrite(IN3, LOW);
  digitalWrite(IN4, HIGH);
  analogWrite(ENA, velRecta);
}

float leerDistancia(int trigPin, int echoPin) {
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);
  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);

  long duracion = pulseIn(echoPin, HIGH, 25000);
  if (duracion == 0) return 0;
  return duracion * 0.034 / 2;
}

void irRecto() {
  myServo.write(anguloRecto);
  analogWrite(ENA, velRecta);
}

void girarIzquierda() {
  myServo.write(anguloIzq);
  analogWrite(ENA, velCurva);
}

void girarDerecha() {
  myServo.write(anguloDer);
  analogWrite(ENA, velCurva);
}

void loop() {
  der = leerDistancia(TRIG_DER, ECHO_DER);
  delay(50);   // <-- da tiempo a que el eco del sensor derecho se disipe
  izq = leerDistancia(TRIG_IZQ, ECHO_IZQ);
  delay(50);   // <-- da tiempo a que el eco del sensor izquierdo se disipe

  Serial.print("Der: "); Serial.print(der);
  Serial.print(" cm | izq: "); Serial.print(izq);
  Serial.println(" cm ");

  float diferencia = izq - der;

  bool izqDisparaGiro = (izq > UMBRAL_GIRO) && (diferencia > MARGEN_DIFERENCIA);
  bool derDisparaGiro = (der > UMBRAL_GIRO) && (-diferencia > MARGEN_DIFERENCIA);

  if (izqDisparaGiro && !derDisparaGiro) {
    girarIzquierda();
  }
  else if (derDisparaGiro && !izqDisparaGiro) {
    girarDerecha();
  }
  else {
    irRecto();
  }
  delay(100);
}

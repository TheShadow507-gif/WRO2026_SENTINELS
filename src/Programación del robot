#include <Servo.h>
#include <Arduino.h>

const int TRIG_DER = 2;
const int ECHO_DER = 4;

const int TRIG_IZQ = 12;
const int ECHO_IZQ = 13;

float der, izq;

const int ENA = 11;
const int IN3 = 10;
const int IN4 = 9;

const int SERVOPIN = 6;
Servo myServo;

// ============================================================
// ZONA DE CONFIGURACIÓN — aquí se ajustan velocidad y ángulos.
// Todo lo de abajo de esta zona es lógica, no tocar.
// ============================================================

// --- VELOCIDAD (PWM 0-255) ---
int velRecta = 170; // velocidad al ir recto //eran 210 al inicio
int velCurva = 170; // velocidad al girar (izq o der)

// --- ÁNGULOS DEL SERVO (grados) ---
int anguloRecto = 90; // recto SIEMPRE debe ser 90. Si el servo no queda
                      // centrado físicamente en 90, es un problema
                      // mecánico del servo/cuerno, no de este código.
int anguloIzq  = 50;  // ángulo al girar izquierda
int anguloDer  = 130; // ángulo al girar derecha

// --- UMBRAL DE DISTANCIA (cm) ---
float UMBRAL_GIRO = 55; // si un lado ve más de esto, se considera "abierto" y gira hacia allá

// --- CONTADOR DE VUELTAS ---
int GIROS_POR_VUELTA = 4; // 1 vuelta = 4 giros (ajusta según tu pista)
int VUELTAS_META     = 3; // detenerse tras esta cantidad de vueltas

// ============================================================
// FIN ZONA DE CONFIGURACIÓN
// ============================================================

int contadorGiros = 0; // cuenta cada giro detectado (no tocar, es lógica)
int girosMeta = GIROS_POR_VUELTA * VUELTAS_META; // se calcula solo (no tocar)

bool girandoAntes = false; // ¿en el ciclo anterior estaba girando?
bool detenido = false;     // true cuando ya cumplió la meta

void setup() {
  Serial.begin(9600);

  pinMode(TRIG_DER, OUTPUT);
  pinMode(ECHO_DER, INPUT);

  pinMode(TRIG_IZQ, OUTPUT);
  pinMode(ECHO_IZQ, INPUT);

  pinMode(ENA, OUTPUT);
  pinMode(IN3, OUTPUT);
  pinMode(IN4, OUTPUT);

  myServo.attach(SERVOPIN);
  myServo.write(anguloRecto);

  digitalWrite(IN3, LOW);
  digitalWrite(IN4, HIGH);
  analogWrite(ENA, velRecta);
}

float leerDistancia(int trigPin, int echoPin) {
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);
  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);

  long duracion = pulseIn(echoPin, HIGH, 25000);
  if (duracion == 0) return 400.0; // sin eco = vía libre, no obstáculo
  return duracion * 0.034 / 2;
}

void irRecto() {
  myServo.write(anguloRecto); // SIEMPRE 90°. Si el servo no va recto aquí,
                              // el problema es el servo, no la lógica de giro.
  analogWrite(ENA, velRecta);
}

void girarIzquierda() {
  myServo.write(anguloIzq);
  analogWrite(ENA, velCurva);
}

void girarDerecha() {
  myServo.write(anguloDer);
  analogWrite(ENA, velCurva);
}

void detenerRobot() {
  myServo.write(anguloRecto);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, LOW);
  analogWrite(ENA, 0);
}

void loop() {
  if (detenido) {
    detenerRobot();
    return; // ya completó las 3 vueltas, no hace nada más
  }

  der = leerDistancia(TRIG_DER, ECHO_DER);
  //delay(50);
  izq = leerDistancia(TRIG_IZQ, ECHO_IZQ);
  //delay(50);

  Serial.print("Der: "); Serial.print(der);
  Serial.print(" cm | Izq: "); Serial.print(izq);
  Serial.println(" cm");

  // El sentido de giro depende ÚNICAMENTE de estas lecturas de los
  // ultrasónicos (der, izq). El servo solo ejecuta lo que aquí se decide.
  bool abrioDer = der > UMBRAL_GIRO;
  bool abrioIzq = izq > UMBRAL_GIRO;
  bool girandoAhora;

  if (abrioDer && !abrioIzq) {
    girarDerecha();
    girandoAhora = true;
  }
  else if (abrioIzq && !abrioDer) {
    girarIzquierda();
    girandoAhora = true;
  }
  else if (abrioDer && abrioIzq) {
    // ambos lados abiertos: gira hacia el que esté más despejado
    if (der > izq) girarDerecha(); else girarIzquierda();
    girandoAhora = true;
  }
  else {
    irRecto();
    girandoAhora = false;
  }

  // --- contador de giros / vueltas ---
  if (girandoAhora && !girandoAntes) { // solo cuenta al ENTRAR a un giro, no en cada ciclo
    contadorGiros++;
    Serial.print("Giro detectado. Total: ");
    delay(250);
    Serial.println(contadorGiros);

    if (contadorGiros >= girosMeta) {
      detenido = true;
    }
  }
  girandoAntes = girandoAhora;

  delay(100);
}
